// 常量手动定义，避免 windres 找不到 MinGW 系统头文件

#define CREATEPROCESS_MANIFEST_RESOURCE_ID 1
#define RT_MANIFEST                        24

#define VS_VERSION_INFO                    1
#define VS_FFI_FILEFLAGSMASK               0x0000003FL
#define VS_FF_DEBUG                        0x00000001L
#define VOS__WINDOWS32                     0x00000004L
#define VFT_APP                            0x00000001L

// Manifest 资源（管理员权限 + 高 DPI + Common Controls v6）
CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "@MANIFEST_PATH@"

// ── 版本信息 ──
VS_VERSION_INFO VERSIONINFO
FILEVERSION     2,0,0,0
PRODUCTVERSION  2,0,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
FILEFLAGS       VS_FF_DEBUG
#else
FILEFLAGS       0
#endif
FILEOS          VOS__WINDOWS32
FILETYPE        VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904E4"
        BEGIN
            VALUE "CompanyName",      "dx11_sync"
            VALUE "FileDescription",  "DX11 Game Multi-Window Synchronizer"
            VALUE "FileVersion",      "2.0.0.0"
            VALUE "InternalName",     "dx11_sync"
            VALUE "LegalCopyright",   ""
            VALUE "OriginalFilename", "dx11_sync.exe"
            VALUE "ProductName",      "dx11_sync"
            VALUE "ProductVersion",   "2.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 0x4E4  // English (U.S.), Unicode
    END
END
